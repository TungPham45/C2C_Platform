generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client/auth"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@localhost:5433/auth_db"
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  full_name  String?   @db.VarChar(255)
  phone      String?   @unique @db.VarChar(20)
  avatar_url String?
  role       String?   @default("user") @db.VarChar(50)
  status     String?   @default("active") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  first_order_at DateTime? @db.Timestamp(6)
  addresses  Address[]
  carts      Cart?
  wallet     Wallet?
  verification_codes VerificationCode[]
  notifications Notification[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model VerificationCode {
  id         Int      @id @default(autoincrement())
  user_id    Int
  code       String   @db.VarChar(10)
  purpose    String   @db.VarChar(50) // 'REGISTER', 'RESET_PASSWORD'
  expires_at DateTime @db.Timestamp(6)
  is_used    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_verif_user_id")
  @@map("verification_codes")
}

model Address {
  id            Int       @id @default(autoincrement())
  user_id       Int
  address_line  String
  city          String?   @db.VarChar(100)
  district      String?   @db.VarChar(100)
  ward          String?   @db.VarChar(100)
  phone_contact String?   @db.VarChar(20)
  type          String?   @db.VarChar(50)
  is_default    Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("addresses")
}

model Cart {
  id         Int       @id @default(autoincrement())
  user_id    Int       @unique
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("carts")
}

model Wallet {
  id           Int                 @id @default(autoincrement())
  user_id      Int                 @unique
  balance      Decimal?            @default(0) @db.Decimal(12, 2)
  created_at   DateTime?           @default(now()) @db.Timestamp(6)
  updated_at   DateTime?           @default(now()) @db.Timestamp(6)
  transactions WalletTransaction[]
  user         User                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("wallets")
}

model WalletTransaction {
  id           Int       @id @default(autoincrement())
  wallet_id    Int
  amount       Decimal   @db.Decimal(12, 2)
  transaction_type String? @db.VarChar(50)
  description  String?   @db.Text
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  wallet       Wallet    @relation(fields: [wallet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("wallet_transactions")
}

model Notification {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(255)
  message    String    @db.Text
  type       String?   @db.VarChar(50) // 'ORDER', 'SYSTEM', 'CHAT'
  link       String?   @db.Text
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_notifications_user_id")
  @@map("notifications")
}
