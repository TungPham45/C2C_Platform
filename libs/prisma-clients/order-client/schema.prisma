// Order Service Prisma Schema
datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@localhost:5432/C2C_Platform"
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client/order"
}

model Voucher {
  id             Int       @id @default(autoincrement())
  shop_id        Int?      // NULL = platform voucher
  code           String    @unique @db.VarChar(50)
  discount_type  String?   @db.VarChar(50) // 'percentage', 'fixed_amount'
  discount_value Decimal   @db.Decimal(12, 2)
  min_spend      Decimal?  @default(0) @db.Decimal(12, 2)
  max_discount   Decimal?  @db.Decimal(12, 2)
  start_date     DateTime? @db.Timestamp(6)
  end_date       DateTime? @db.Timestamp(6)
  usage_limit    Int?
  created_at     DateTime? @default(now()) @db.Timestamp(6)

  shop           Shop?           @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  checkout_sessions CheckoutSession[]
  shop_orders    ShopOrder[]

  @@map("vouchers")
}

model CheckoutSession {
  id                  Int       @id @default(autoincrement())
  user_id             Int
  total_payment       Decimal   @db.Decimal(12, 2)
  payment_method      String?   @db.VarChar(50) // 'cod', 'shopeepay', 'credit_card', 'wallet'
  payment_status      String?   @default("unpaid") @db.VarChar(50) // 'unpaid', 'paid', 'failed'
  platform_voucher_id Int?
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)

  user                User      @relation(fields: [user_id], references: [id])
  platform_voucher    Voucher?  @relation(fields: [platform_voucher_id], references: [id])
  shop_orders         ShopOrder[]

  @@map("checkout_sessions")
}

model ShopOrder {
  id                  Int       @id @default(autoincrement())
  checkout_session_id Int
  shop_id             Int
  subtotal            Decimal   @db.Decimal(12, 2)
  shipping_fee        Decimal   @db.Decimal(12, 2)
  shop_voucher_id     Int?
  shipping_address    String    @db.Text
  status              String?   @default("pending") @db.VarChar(50) // 'pending', 'to_ship', 'shipping', 'completed', 'cancelled', 'returned'
  tracking_number     String?   @unique @db.VarChar(100)
  carrier_name        String?   @db.VarChar(100)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)

  checkout_session    CheckoutSession @relation(fields: [checkout_session_id], references: [id], onDelete: Cascade)
  shop                Shop            @relation(fields: [shop_id], references: [id])
  shop_voucher        Voucher?        @relation(fields: [shop_voucher_id], references: [id])
  items               OrderItem[]

  @@map("shop_orders")
}

model OrderItem {
  id                 Int       @id @default(autoincrement())
  shop_order_id      Int
  product_variant_id Int
  product_name       String    @db.VarChar(255)
  variant_details    Json?
  quantity           Int
  price_at_purchase  Decimal   @db.Decimal(12, 2)
  created_at         DateTime? @default(now()) @db.Timestamp(6)

  shop_order         ShopOrder @relation(fields: [shop_order_id], references: [id], onDelete: Cascade)
  product_variant    ProductVariant @relation(fields: [product_variant_id], references: [id])

  @@map("order_items")
}

// Stubs for relations across independent microservices
model Shop {
  id           Int           @id @default(autoincrement())
  vouchers     Voucher[]
  shop_orders  ShopOrder[]
  @@map("shops")
}
model User {
  id                Int               @id @default(autoincrement())
  checkout_sessions CheckoutSession[]
  @@map("users")
}
model ProductVariant {
  id          Int           @id @default(autoincrement())
  order_items OrderItem[]
  @@map("product_variants")
}
