generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client/order"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@localhost:5433/order_db"
}

model Voucher {
  id                Int               @id @default(autoincrement())
  shop_id           Int?
  code              String            @unique @db.VarChar(50)
  discount_type     String?           @db.VarChar(50)
  discount_value    Decimal           @db.Decimal(12, 2)
  min_spend         Decimal?          @default(0) @db.Decimal(12, 2)
  max_discount      Decimal?          @db.Decimal(12, 2)
  start_date        DateTime?         @db.Timestamp(6)
  end_date          DateTime?         @db.Timestamp(6)
  usage_limit       Int?
  created_at        DateTime?         @default(now()) @db.Timestamp(6)
  checkout_sessions CheckoutSession[]
  shop_orders       ShopOrder[]

  @@map("vouchers")
}

model CartItem {
  id                 Int       @id @default(autoincrement())
  cart_id            Int
  shop_id            Int
  product_variant_id Int
  quantity           Int?      @default(1)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)

  @@index([cart_id], map: "idx_cart_items_cart_id")
  @@map("cart_items")
}

model CheckoutSession {
  id                  Int         @id @default(autoincrement())
  user_id             Int
  total_payment       Decimal     @db.Decimal(12, 2)
  payment_method      String?     @db.VarChar(50)
  payment_status      String?     @default("unpaid") @db.VarChar(50)
  platform_voucher_id Int?
  created_at          DateTime?   @default(now()) @db.Timestamp(6)
  updated_at          DateTime?   @default(now()) @db.Timestamp(6)
  platform_voucher    Voucher?    @relation(fields: [platform_voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop_orders         ShopOrder[]

  @@map("checkout_sessions")
}

model ShopOrder {
  id                  Int             @id @default(autoincrement())
  checkout_session_id Int
  shop_id             Int
  subtotal            Decimal         @db.Decimal(12, 2)
  shipping_fee        Decimal         @db.Decimal(12, 2)
  shop_voucher_id     Int?
  shipping_address    String
  status              String?         @default("pending") @db.VarChar(50)
  tracking_number     String?         @unique @db.VarChar(100)
  carrier_name        String?         @db.VarChar(100)
  created_at          DateTime?       @default(now()) @db.Timestamp(6)
  updated_at          DateTime?       @default(now()) @db.Timestamp(6)
  items               OrderItem[]
  checkout_session    CheckoutSession @relation(fields: [checkout_session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  shop_voucher        Voucher?        @relation(fields: [shop_voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([checkout_session_id], map: "idx_shop_orders_checkout_session_id")
  @@map("shop_orders")
}

model OrderItem {
  id                 Int       @id @default(autoincrement())
  shop_order_id      Int
  product_variant_id Int
  product_name       String    @db.VarChar(255)
  variant_details    Json?
  quantity           Int
  price_at_purchase  Decimal   @db.Decimal(12, 2)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  shop_order         ShopOrder @relation(fields: [shop_order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("order_items")
}
